rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * Harmony OS Enterprise Security Rules
     *
     * PHILOSOPHY:
     * - Sovereign Authorization: Deny by default.
     * - Tiered Sovereignty: SuperAdmin > Executive > Operations > Viewer.
     * - Compartmentalization: Department-based data isolation for Operations.
     * - Record-Level Visibility: Public, Internal, Shared, and Private states.
     * - Integrity: Audit and Activity logs are immutable by clients.
     */

    // --- GLOBAL HELPERS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn() && (
        get(/databases/$(database)/documents/staffMembers/$(request.auth.uid)).data.role == 'SuperAdmin' ||
        request.auth.token.role == 'SuperAdmin'
      );
    }

    function hasRole(role) {
      return isSignedIn() && (
        get(/databases/$(database)/documents/staffMembers/$(request.auth.uid)).data.role == role ||
        request.auth.token.role == role
      );
    }

    function hasAnyRole(roles) {
      return isSignedIn() && (
        get(/databases/$(database)/documents/staffMembers/$(request.auth.uid)).data.role in roles ||
        request.auth.token.role in roles
      );
    }

    function isDeptMember(deptId) {
      let staff = get(/databases/$(database)/documents/staffMembers/$(request.auth.uid)).data;
      return isSuperAdmin() || (staff != null && staff.departmentId == deptId);
    }

    function isOwner(data) {
      return isSignedIn() && (data.ownerId == request.auth.uid || data.createdBy == request.auth.uid);
    }

    function isSharedWith(data) {
      return isSignedIn() && (request.auth.uid in data.sharedWith || request.auth.uid in data.watcherIds);
    }

    function isRecordVisible(data) {
      // visibility: 'Public', 'Internal', 'Department', 'Shared', 'Private'
      return isSuperAdmin() ||
             hasRole('Executive') ||
             isOwner(data) ||
             isSharedWith(data) ||
             (data.visibility == 'Public') ||
             (data.visibility == 'Internal' && isSignedIn()) ||
             (data.visibility == 'Department' && isDeptMember(data.departmentId));
    }

    // --- COLLECTION RULES ---

    // Deny all by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Staff/User Profiles
    match /staffMembers/{userId} {
      allow get: if isSuperAdmin() || request.auth.uid == userId;
      allow list: if isSuperAdmin() || hasRole('Executive') || hasRole('DepartmentHead');
      allow create, update: if isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    match /users/{userId} {
      allow get, update: if request.auth.uid == userId || isSuperAdmin() || hasAnyRole(['Executive', 'Operations', 'ClientServicing']);
      allow list: if isSuperAdmin() || hasAnyRole(['Executive', 'Operations', 'ClientServicing']);
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow delete: if isSuperAdmin();
    }

    // Departments / Organizations
    match /departments/{deptId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    match /organizations/{orgId} {
      allow read: if isRecordVisible(resource.data);
      allow create: if isSignedIn();
      allow update: if isSuperAdmin() || hasRole('Executive') || isOwner(resource.data) || isDeptMember(resource.data.departmentId);
      allow delete: if isSuperAdmin();
    }

    // CRM: Contacts & Deals
    match /contacts/{contactId} {
      allow read: if isRecordVisible(resource.data);
      allow create: if isSignedIn();
      allow update: if isSuperAdmin() || hasRole('Executive') || isOwner(resource.data) || isDeptMember(resource.data.departmentId);
      allow delete: if isSuperAdmin();
    }

    match /deals/{dealId} {
      allow read: if isRecordVisible(resource.data);
      allow create: if isSignedIn();
      allow update: if isSuperAdmin() || hasRole('Executive') || isOwner(resource.data) || isDeptMember(resource.data.departmentId);
      allow delete: if isSuperAdmin();
    }

    // Inquiries / Cases
    match /cases/{caseId} {
      allow read: if isRecordVisible(resource.data);
      allow create: if true; // Inquiries can be public anonymous
      allow update: if isSuperAdmin() || hasRole('Executive') || isOwner(resource.data) || isDeptMember(resource.data.departmentId) || hasRole('ClientServicing');
      allow delete: if isSuperAdmin();
    }

    // Projects / Pipelines
    match /projects/{projectId} {
      allow read: if isRecordVisible(resource.data);
      allow create: if isSuperAdmin() || hasAnyRole(['Executive', 'Operations', 'DepartmentHead']);
      allow update: if isSuperAdmin() || hasRole('Executive') || isOwner(resource.data) || isDeptMember(resource.data.departmentId);
      allow delete: if isSuperAdmin();
    }

    // Tasks & Handoffs
    match /tasks/{taskId} {
      allow read: if isRecordVisible(resource.data);
      allow create: if isSignedIn();
      allow update: if isSuperAdmin() || 
                    hasRole('Executive') || 
                    isOwner(resource.data) || 
                    isDeptMember(resource.data.departmentId) || 
                    request.auth.uid == resource.data.assignedTo;
      allow delete: if isSuperAdmin() || isOwner(resource.data);
    }

    match /handoffs/{handoffId} {
      allow read: if isRecordVisible(resource.data) || isDeptMember(resource.data.fromDepartmentId) || isDeptMember(resource.data.toDepartmentId);
      allow create: if isSignedIn();
      allow update: if isSuperAdmin() || hasRole('Executive') || isOwner(resource.data) || isDeptMember(resource.data.fromDepartmentId) || isDeptMember(resource.data.toDepartmentId);
      allow delete: if isSuperAdmin();
    }

    // Assets / Files (Vault)
    match /files/{fileId} {
      allow read: if isRecordVisible(resource.data);
      allow create: if isSignedIn();
      allow update: if isSuperAdmin() || hasRole('Executive') || isOwner(resource.data) || isDeptMember(resource.data.departmentId);
      allow delete: if isSuperAdmin() || isOwner(resource.data);
    }

    // Finance & Approvals
    match /financeEntries/{entryId} {
      allow read, write: if isSuperAdmin() || hasAnyRole(['Executive', 'Finance']);
    }

    match /approvals/{approvalId} {
      allow read: if isSuperAdmin() || hasRole('Executive') || isOwner(resource.data) || (request.auth.uid in resource.data.approverIds);
      allow create: if isSignedIn();
      allow update: if isSuperAdmin() ||
                    (hasRole('Executive') && (request.auth.uid in resource.data.approverIds)) ||
                    (isOwner(resource.data) && resource.data.status == 'Pending'); 
      allow delete: if isSuperAdmin();
    }

    // Intelligence Logs (Audit & Activity)
    match /activityLogs/{logId} {
      allow get: if isSuperAdmin() || hasRole('Executive') || resource.data.userId == request.auth.uid;
      allow list: if isSuperAdmin() || hasRole('Executive') || isDeptMember(resource.data.departmentId);
      allow create: if isSignedIn() 
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.createdAt == request.time;
      allow update, delete: if false;
    }

    match /auditLogs/{logId} {
      allow read: if isSuperAdmin() || hasRole('Executive');
      allow create: if isSuperAdmin(); // Restricted to SuperAdmin for now until server-side logic is implemented
      allow update, delete: if false; 
    }
  }
}